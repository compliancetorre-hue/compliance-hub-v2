# ============================================================
# COMPLIANCE HUB - Variaveis de Ambiente
# IMPORTANTE: Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositorio!
# ============================================================

# Servidor
NODE_ENV=development
PORT=3001

# Seguranca JWT
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_UM_SEGREDO_FORTE_DE_64_CARACTERES
JWT_EXPIRES_IN=8h

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=compliance_hub
DB_USER=compliance_user
DB_PASSWORD=SUBSTITUA_POR_SENHA_FORTE
DB_SSL=false

# CORS - Origens permitidas (separadas por virgula)
ALLOWED_ORIGINS=http://localhost:3000,https://seudominio.com.br

# Logs
LOG_LEVEL=info

# Email (para notificacoes - opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@seudominio.com.br
